{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm ci --prefix wp-content/themes/Campanha_02 && npm run build --prefix wp-content/themes/Campanha_02",
  "outputDirectory": "wp-content/themes/Campanha_02/dist",
  "installCommand": "echo \"Dependencies are installed in buildCommand\"",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
